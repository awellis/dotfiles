{
  "$schema": "https://opencode.ai/config.json",
  "share": "manual",
  "autoupdate": true,
  "disabled_providers": [],
  "model": "lmstudio/qwen/qwen3.5-9b",
  "agent": {
    "plan": {
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "description": "Planning agent - read-only exploration and design",
      "mode": "primary",
      "options": {},
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "build": {
      "description": "Primary coding agent with full tool access",
      "mode": "primary",
      "options": {},
      "permission": {
        "bash": {
          "*": "ask",
          "git status *": "allow",
          "git diff *": "allow",
          "git log *": "allow"
        }
      }
    }
  },
  "provider": {
    "lmstudio": {
      "name": "LMStudio",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "openai/gpt-oss-20b": {
          "name": "gpt-oss-20b"
        },
        "qwen/qwen3.5-9b": {
          "name": "Qwen 3.5 9B"
        }
      },
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    }
  },
  "mcp": {
    "pencil": {
      "command": [
        "/Users/andrew/.vscode/extensions/highagency.pencildev-0.6.30/out/mcp-server-darwin-arm64",
        "--app",
        "visual_studio_code"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  }
}