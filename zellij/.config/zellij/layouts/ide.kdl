layout {
    pane split_direction="vertical" {
        pane size="65%" {
            command "nvim"
        }
        pane size="35%" split_direction="horizontal" {
            pane size="70%" {
                command "fish"
                args "-c" "claude-ide"
            }
            pane size="30%"
        }
    }
    pane size=1 borderless=true {
        plugin location="compact-bar"
    }
}
